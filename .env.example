# ============================================================================
# ollapoc — Environment Configuration Reference
# ============================================================================
# Copy this file to .env and fill in all values before running docker compose.
# .env is in .gitignore and must NEVER be committed.
# All values here are safe defaults for local development (no real secrets).
# ============================================================================

# ── Ollama ───────────────────────────────────────────────────────────────────
# Base URL for the Ollama API (from inside the Docker network).
OLLAMA_BASE_URL=http://ollama:11434

# Chat model to use. Options:
#   qwen3:8b       — default, fits 8 GB VRAM (work laptop)
#   qwen3:14b      — 16 GB VRAM (home laptop, better UC-3 IR quality)
#   qwen3:4b       — CPU fallback only (64 GB RAM server)
OLLAMA_CHAT_MODEL=qwen3:8b

# Embedding model. 384-dim, fast on both CPU and GPU.
# bge-small-en-v1.5 was removed from the Ollama registry; all-minilm is the drop-in replacement.
OLLAMA_EMBEDDING_MODEL=all-minilm

# Number of parallel LLM calls Ollama will accept. Keep at 1 for POC.
# Increase only after measuring queue behaviour under load.
OLLAMA_NUM_PARALLEL=1

# Number of GPU layers to offload. 999 = all layers (full GPU inference).
# Set to 0 for CPU-only mode.
OLLAMA_NUM_GPU=999

# ── Elasticsearch ────────────────────────────────────────────────────────────
# ES cluster URL (from inside the Docker network).
ES_URL=http://elasticsearch:9200

# Basic auth credentials. Change the password in production.
ES_USERNAME=elastic
ES_PASSWORD=changeme

# RAG index names. Change only if you have naming conflicts.
ES_INDEX_DOCS=docs
ES_INDEX_CATALOG_TERMS=catalog_terms
ES_INDEX_SCHEMA_CARDS=schema_cards

# Pattern used to discover operational (business) ES indices for UC-3.
# Supports wildcards, e.g. "business_*" or "ops_*,client_*".
ES_OPERATIONAL_INDEX_PATTERN=business_*

# Max sample values to fetch per keyword field for schema cards.
ES_OPERATIONAL_MAX_SAMPLE_VALUES=5

# ── OIDC Authentication ───────────────────────────────────────────────────────
# Corporate IdP discovery URL (OpenID Connect).
OIDC_AUTHORITY=https://your-idp.example.com

# Application client credentials (registered in your IdP).
OIDC_CLIENT_ID=ollapoc
OIDC_CLIENT_SECRET=<replace-with-real-secret>
OIDC_CALLBACK_PATH=/signin-oidc

# Set to true in local dev override (docker-compose.override.yml) to bypass OIDC.
# Must be false in any shared or demo environment.
SKIP_AUTH=false

# ── SQL Server Catalog ───────────────────────────────────────────────────────
# Connection string for the SQL Server metadata catalog.
# Use a read-only service account (svc_ai or similar).
SQL_CONNECTION_STRING=Server=your-sql-server;Database=CatalogDB;User Id=svc_ai;Password=<replace>;TrustServerCertificate=true;

# Table names in the catalog database (schema-qualified if needed).
SQL_CATALOG_SCHEMA=dbo
SQL_ENTITY_TABLE=Entities
SQL_ATTRIBUTE_TABLE=Attributes
SQL_CDE_TABLE=CriticalDataElements
SQL_RELATIONSHIP_TABLE=EntityRelationships

# ── MongoDB Catalog Extension ────────────────────────────────────────────────
# Connection string for the MongoDB extension attribute store.
MONGO_CONNECTION_STRING=mongodb://svc_ai:<replace>@your-mongo-host:27017
MONGO_DATABASE_NAME=CatalogExtensions
MONGO_EXTENSIONS_COLLECTION=EntityExtensions

# ── Confluence ───────────────────────────────────────────────────────────────
# Atlassian Cloud base URL (wiki subdomain).
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki

# Service account email and API token (Atlassian API token, not password).
CONFLUENCE_USERNAME=svc-ai-assistant@yourcompany.com
CONFLUENCE_API_TOKEN=<replace-with-atlassian-api-token>

# Comma-separated list of Confluence space keys to crawl.
CONFLUENCE_SPACES=ENG,OPS,PROD

# Cron schedule for incremental sync (default: every hour).
CONFLUENCE_INCREMENTAL_CRON=0 * * * *

# Cron schedule for full sync (default: daily at 02:00).
CONFLUENCE_FULL_SYNC_CRON=0 2 * * *

# Rate limit for Confluence REST API calls (requests per second).
CONFLUENCE_RATE_LIMIT_RPS=5

# ── Jira ─────────────────────────────────────────────────────────────────────
# Atlassian Cloud base URL.
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Service account email and API token (same account as Confluence is fine).
JIRA_USERNAME=svc-ai-assistant@yourcompany.com
JIRA_API_TOKEN=<replace-with-atlassian-api-token>

# Comma-separated list of Jira project keys to crawl.
JIRA_PROJECTS=ENG,OPS

# Cron schedule for incremental sync.
JIRA_INCREMENTAL_CRON=0 * * * *

# Rate limit for Jira REST API calls.
JIRA_RATE_LIMIT_RPS=5

# ── Ingestion Tuning ─────────────────────────────────────────────────────────
# Target tokens per chunk (semantic chunking). ~500 tokens ≈ ~375 words.
INGESTION_CHUNK_TARGET_TOKENS=500

# Overlap between consecutive chunks in tokens.
INGESTION_CHUNK_OVERLAP_TOKENS=50

# Number of chunks to embed in a single IEmbeddingGenerator batch call.
INGESTION_BATCH_EMBED_SIZE=32

# Cron schedules for catalog ingestion (SQL and MongoDB).
INGESTION_CATALOG_SQL_CRON=*/15 * * * *
INGESTION_CATALOG_MONGO_CRON=*/15 * * * *

# Cron schedule for schema-card refresh from ES mappings.
INGESTION_ES_MAPPING_CRON=0 */6 * * *

# ── RAG Server ───────────────────────────────────────────────────────────────
# Port the ASP.NET Core app listens on (mapped by Docker Compose).
RAG_HOST_PORT=8080

# Maximum number of LLM requests queued before returning 429.
RAG_QUEUE_MAX_DEPTH=50

# In-process LRU cache size for query embeddings (number of entries).
RAG_EMBEDDING_CACHE_SIZE=1000

# Maximum output tokens for the chat endpoint response.
RAG_CHAT_MAX_OUTPUT_TOKENS=512

# ── Docs Pipeline (UC-1) ─────────────────────────────────────────────────────
# Number of chunks to retrieve and include in the grounded prompt.
RAG_DOCS_TOP_K=5

# RRF rank constant (k in 1/(k+rank)). 60 is the ES default.
RAG_DOCS_RRF_RANK_CONSTANT=60

# ── Metadata Pipeline (UC-2) ─────────────────────────────────────────────────
# Maximum tool-calling rounds before returning with partial results.
RAG_METADATA_MAX_TOOL_ROUNDS=8

# Optional extra instructions appended to the metadata system prompt.
RAG_METADATA_SYSTEM_PROMPT_EXTRA=

# ── Data Pipeline (UC-3) ─────────────────────────────────────────────────────
# Maximum tokens for the IR generation response.
RAG_UC3_IR_MAX_TOKENS=250

# Maximum retries for IR generation on validation failure. Keep at 1 for POC.
RAG_UC3_MAX_RETRIES=1

# Maximum rows returned by the ES search query.
RAG_UC3_MAX_RESULT_ROWS=50

# Maximum tokens for the result formatting response.
RAG_UC3_RESULT_FORMAT_MAX_TOKENS=400

# Whether to call ES _validate/query before _search. Recommended: true.
RAG_UC3_VALIDATE_BEFORE_SEARCH=true

# Minimum confidence score for ResolveEntity to accept a match (0.0–1.0).
RAG_UC3_ENTITY_RESOLVE_THRESHOLD=0.5

# Schema-card cache TTL in seconds. Cache rebuilds on ES mapping change.
RAG_UC3_SCHEMA_CARD_CACHE_TTL_SECONDS=300

# ── Observability ────────────────────────────────────────────────────────────
# OTLP exporter endpoint (gRPC).
# In-Docker (container-to-container): use the INTERNAL container port 18889
# Host-direct (dotnet run outside Docker): use the HOST-mapped port 4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://aspire-dashboard:18889

# Service name shown in the Aspire Dashboard for the main RAG server.
OTEL_SERVICE_NAME=rag-server

# Service name for the ingestion hosted service (appears as separate service).
OTEL_CRAWLER_SERVICE_NAME=rag-ingestion

# ── Aspire Dashboard ─────────────────────────────────────────────────────────
# UI port accessible from the host browser.
ASPIRE_DASHBOARD_UI_PORT=18888

# OTLP gRPC port (services send traces/metrics here).
ASPIRE_DASHBOARD_OTLP_GRPC_PORT=4317

# OTLP HTTP port (alternative to gRPC).
ASPIRE_DASHBOARD_OTLP_HTTP_PORT=4318

# Set to true to disable the Aspire Dashboard login screen (POC only).
ASPIRE_DASHBOARD_UNSECURED=true

# Set to true to bind Aspire Dashboard to localhost only during the demo.
ASPIRE_BIND_LOCALHOST_ONLY=true

# ── Demo & A/B Testing ───────────────────────────────────────────────────────
# Enable demo mode (hides internal plumbing, activates curated query picker).
DEMO_MODE=false

# Enable the Demo Stats panel in the Blazor UI sidebar.
DEMO_STATS_ENABLED=true

# Set to true to hide retrieved chunks and raw tool results (demo audiences).
DEMO_DEBUG_PANEL=false

# Comma-separated extra queries to pre-warm in addition to DemoQueries.json.
# Leave empty to use only the built-in curated queries.
DEMO_PRE_WARMED_QUERIES=

# A/B test: set to true to alternate between MODEL_A and MODEL_B.
AB_TEST_ENABLED=false
AB_TEST_MODEL_A=qwen3:8b
AB_TEST_MODEL_B=qwen3:14b

# UC-3 Data pipeline tuning
RAG_DATA_MAX_RETRIES=1
RAG_DATA_IR_MAX_TOKENS=500

# ── SQL Server container credentials ─────────────────────────────────────────
# SA password for the SQL Server container (Developer Edition — local only).
SQL_SA_PASSWORD=Strong!Pass1
# Inside Docker: use service name 'mssql' (internal port 1433, no change needed).
SQL_CONNECTION_STRING=Server=mssql;Database=CatalogDB;User Id=sa;Password=Strong!Pass1;TrustServerCertificate=true;
# From host tools (SSMS, Azure Data Studio): connect to localhost,14330 — host port was changed
# from 1433 to 14330 to avoid conflict with local SQL Server or Windows Hyper-V port reservations.

# ── MongoDB container credentials ────────────────────────────────────────────
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=rootpassword
# Override the connection string for the Docker network:
MONGO_CONNECTION_STRING=mongodb://root:rootpassword@mongodb:27017
MONGO_DATABASE_NAME=catalog
MONGO_EXTENSIONS_COLLECTION=entity_extensions
MONGO_RULES_COLLECTION=entity_rules

# ── Confluence mock ───────────────────────────────────────────────────────────
# Point the crawler at the local mock (from inside Docker network):
CONFLUENCE_BASE_URL=http://confluence-mock:8090
# Browser-accessible URL for citation links (host-side address):
CONFLUENCE_PUBLIC_URL=http://localhost:8090
CONFLUENCE_USERNAME=demo
CONFLUENCE_API_TOKEN=demo
CONFLUENCE_SPACES=MDM
