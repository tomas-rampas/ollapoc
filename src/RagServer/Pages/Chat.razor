@page "/"
@page "/chat"
@rendermode InteractiveServer
@using Markdig
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Options
@using RagServer.Options
@implements IAsyncDisposable
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IOptions<OllamaOptions> OllamaOpts
@inject IOptions<DemoOptions> DemoOpts

<div class="chat-wrapper">
    <div class="chat-main">
        <div class="messages" id="messages">
            @foreach (var m in _messages)
            {
                <div class="msg @m.Role">
                    <span class="role-label">@m.Role</span>
                    @if (m.Role == "assistant" && m.Pipeline is not null)
                    {
                        <span class="pipeline-badge badge-@m.Pipeline.ToLower()">@m.Pipeline</span>
                    }
                    <div class="text @(m.IsError ? "error-text" : "")">@((MarkupString)RenderMd(m.Text))</div>
                    @if (m.Citations?.Count > 0)
                    {
                        <div class="citations">
                            @foreach (var c in m.Citations)
                            {
                                <span>[@c.Index]</span>
                                @if (!string.IsNullOrEmpty(c.Url) &&
                                     (c.Url.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
                                      c.Url.StartsWith("http://",  StringComparison.OrdinalIgnoreCase)))
                                {
                                    <a href="@c.Url" target="_blank" rel="noopener noreferrer">@(c.Title ?? c.Url)</a>
                                }
                                else
                                {
                                    <span>@c.Title</span>
                                }
                                <span> </span>
                            }
                        </div>
                    }
                </div>
            }
            @if (_busy)
            {
                <div class="msg assistant thinking">
                    <span class="role-label">assistant</span>
                    <span class="thinking-dots"><span>.</span><span>.</span><span>.</span></span>
                </div>
            }
        </div>
        <div class="input-bar">
            <input @bind="_input"
                   @bind:event="oninput"
                   @onkeydown="OnKeyAsync"
                   placeholder="Ask anything…"
                   disabled="@_busy" />
            <button @onclick="SendAsync" disabled="@_busy">Send</button>
        </div>
    </div>

    @if (DemoOpts.Value.DemoStatsEnabled)
    {
        <aside class="stats-panel">
            <h3>Demo Stats</h3>
            <dl>
                <dt>Pipeline</dt>
                <dd>@_lastPipeline</dd>
                <dt>Model</dt>
                <dd>@_statsModelName</dd>
                <dt>Latency</dt>
                <dd>@(_lastLatencyMs > 0 ? $"{_lastLatencyMs} ms" : "—")</dd>
                <dt>Tokens</dt>
                <dd>@(_lastTokensGenerated.HasValue ? _lastTokensGenerated.Value.ToString() : "—")</dd>
                <dt>Tokens/s</dt>
                <dd>@(_lastTokensPerSecond.HasValue ? $"{_lastTokensPerSecond.Value:F1}" : "—")</dd>
                @if (_lastToolCallCount.HasValue)
                {
                    <dt>Tool Calls</dt>
                    <dd>@_lastToolCallCount.Value</dd>
                }
                @if (_lastIrFirstTry.HasValue)
                {
                    <dt>IR First Try</dt>
                    <dd>@(_lastIrFirstTry.Value ? "yes" : "no")</dd>
                }
                @if (_lastResultRows.HasValue)
                {
                    <dt>Result Rows</dt>
                    <dd>@_lastResultRows.Value</dd>
                }
            </dl>
        </aside>
    }
</div>

@code {
    private static readonly MarkdownPipeline MdPipeline =
        new MarkdownPipelineBuilder().DisableHtml().UseAdvancedExtensions().Build();

    private static string RenderMd(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        var html = Markdown.ToHtml(text, MdPipeline);
        // Open all rendered links in a new tab (entity detail links and citation links)
        return html.Replace("<a href=", "<a target=\"_blank\" rel=\"noopener noreferrer\" href=");
    }

    private sealed record ChatMsg(
        string Role,
        string Text = "",
        string? Pipeline = null,
        bool IsError = false,
        IReadOnlyList<CitationLink>? Citations = null);

    private sealed record CitationLink(int Index, string? Title, string? Url);

    private string _input = "";
    private bool _busy;
    private string _lastPipeline = "—";
    private string _statsModelName = "";
    private long _lastLatencyMs;
    private int? _lastTokensGenerated;
    private double? _lastTokensPerSecond;
    private int? _lastToolCallCount;
    private bool? _lastIrFirstTry;
    private int? _lastResultRows;
    private IReadOnlyList<CitationLink>? _pendingCitations;
    private readonly List<ChatMsg> _messages = [];

    // Component-level CTS cancelled when the circuit disposes (user closes tab)
    private readonly CancellationTokenSource _disposeCts = new();

    protected override void OnInitialized() =>
        _statsModelName = OllamaOpts.Value.ChatModel;

    private async Task OnKeyAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendAsync();
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_input) || _busy) return;

        _busy = true;
        var userMsg = _input;
        _input = "";
        _messages.Add(new ChatMsg("user", userMsg));
        await InvokeAsync(StateHasChanged);

        var sw = System.Diagnostics.Stopwatch.StartNew();
        var sb = new System.Text.StringBuilder();
        _messages.Add(new ChatMsg("assistant"));
        var idx = _messages.Count - 1;

        // Reset per-request stats
        _lastTokensGenerated = null;
        _lastTokensPerSecond = null;
        _lastToolCallCount = null;
        _lastIrFirstTry = null;
        _lastResultRows = null;
        _pendingCitations = null;

        // Per-send CTS with 120-second hard timeout, cancelled on circuit dispose
        using var sendCts = CancellationTokenSource.CreateLinkedTokenSource(_disposeCts.Token);
        sendCts.CancelAfter(TimeSpan.FromSeconds(120));

        try
        {
            using var http = HttpFactory.CreateClient("rag");
            // BaseAddress from NavigationManager so it works on any port/host
            http.BaseAddress = new Uri(Nav.BaseUri);

            // _messages already contains the current user msg + empty assistant placeholder at the tail;
            // skip them and send the preceding turns as context for follow-up routing.
            var history = _messages
                .SkipLast(2)
                .TakeLast(10)
                .Select(m => new { role = m.Role, content = m.Text, pipeline = m.Pipeline })
                .ToList();

            using var request = new HttpRequestMessage(HttpMethod.Post, "/api/chat")
            {
                Content = JsonContent.Create(new { message = userMsg, history })
            };
            using var resp = await http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead,
                sendCts.Token);
            resp.EnsureSuccessStatusCode();

            using var stream = await resp.Content.ReadAsStreamAsync(sendCts.Token);
            using var reader = new System.IO.StreamReader(stream);

            // Read until EOF — avoid reader.EndOfStream (blocks on streaming HTTP responses)
            // eventHasData tracks whether the current SSE event has already received a data: line.
            // Per SSE spec, consecutive data: lines within one event are joined with \n.
            string? line;
            bool eventHasData = false;
            while ((line = await reader.ReadLineAsync(sendCts.Token)) is not null)
            {
                if (line.Length == 0)
                {
                    // Empty line = SSE event boundary; reset for the next event
                    eventHasData = false;
                    continue;
                }

                if (line.StartsWith("event: pipeline", StringComparison.Ordinal))
                {
                    var dataLine = await reader.ReadLineAsync(sendCts.Token);
                    if (dataLine?.StartsWith("data: ", StringComparison.Ordinal) == true)
                        _lastPipeline = dataLine["data: ".Length..];
                    eventHasData = false;
                }
                else if (line.StartsWith("event: stats", StringComparison.Ordinal))
                {
                    var dataLine = await reader.ReadLineAsync(sendCts.Token);
                    if (dataLine?.StartsWith("data: ", StringComparison.Ordinal) == true)
                        ParseStats(dataLine["data: ".Length..]);
                    eventHasData = false;
                }
                else if (line.StartsWith("event: citations", StringComparison.Ordinal))
                {
                    var dataLine = await reader.ReadLineAsync(sendCts.Token);
                    if (dataLine?.StartsWith("data: ", StringComparison.Ordinal) == true)
                        _pendingCitations = ParseCitations(dataLine["data: ".Length..]);
                    eventHasData = false;
                }
                else if (line.StartsWith("event: ", StringComparison.Ordinal))
                {
                    // Unhandled named event — consume its data: line and discard
                    await reader.ReadLineAsync(sendCts.Token);
                    eventHasData = false;
                }
                else if (line.StartsWith("data: ", StringComparison.Ordinal))
                {
                    var token = line["data: ".Length..];
                    if (token == "[DONE]") break;
                    if (token.StartsWith("[ERROR]", StringComparison.Ordinal))
                    {
                        _messages[idx] = _messages[idx] with { IsError = true };
                        break;
                    }
                    // SSE spec: consecutive data: lines within the same event join with \n
                    if (eventHasData) sb.Append('\n');
                    sb.Append(token);
                    eventHasData = true;
                    _messages[idx] = _messages[idx] with { Text = sb.ToString() };
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            if (_messages[idx].Text.Length == 0)
                _messages[idx] = new ChatMsg("assistant", "[Request timed out or cancelled]", IsError: true);
        }
        catch (Exception ex)
        {
            _messages[idx] = new ChatMsg("assistant", $"[Error: {ex.Message}]", IsError: true);
        }
        finally
        {
            sw.Stop();
            _lastLatencyMs = sw.ElapsedMilliseconds;
            _busy = false;
            if (idx >= 0 && idx < _messages.Count)
            {
                _messages[idx] = _messages[idx] with
                {
                    Pipeline  = _lastPipeline == "—" ? null : _lastPipeline,
                    Citations = _pendingCitations
                };
            }
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ParseStats(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;

            if (root.TryGetProperty("modelName", out var modelEl) && modelEl.ValueKind == System.Text.Json.JsonValueKind.String)
                _statsModelName = modelEl.GetString() ?? _statsModelName;

            if (root.TryGetProperty("tokensGenerated", out var tokEl) && tokEl.TryGetInt32(out var toks))
                _lastTokensGenerated = toks;

            if (root.TryGetProperty("tokensPerSecond", out var tpsEl) && tpsEl.TryGetDouble(out var tps))
                _lastTokensPerSecond = tps;

            if (root.TryGetProperty("toolCallCount", out var tcEl) && tcEl.TryGetInt32(out var tc))
                _lastToolCallCount = tc;

            if (root.TryGetProperty("irValidFirstTry", out var irEl) &&
                (irEl.ValueKind == System.Text.Json.JsonValueKind.True || irEl.ValueKind == System.Text.Json.JsonValueKind.False))
                _lastIrFirstTry = irEl.GetBoolean();

            if (root.TryGetProperty("totalResultRows", out var rrEl) && rrEl.TryGetInt32(out var rr))
                _lastResultRows = rr;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Chat] ParseStats failed: {ex.Message}");
        }
    }

    private List<CitationLink> ParseCitations(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var list = new List<CitationLink>();
            foreach (var el in doc.RootElement.EnumerateArray())
            {
                var index = el.TryGetProperty("index", out var idx) ? idx.GetInt32() : 0;
                var title = el.TryGetProperty("title", out var t) ? t.GetString() : null;
                var url   = el.TryGetProperty("url",   out var u) ? u.GetString() : null;
                list.Add(new CitationLink(index, title, url));
            }
            return list;
        }
        catch { return []; }
    }

    public ValueTask DisposeAsync()
    {
        _disposeCts.Cancel();
        _disposeCts.Dispose();
        return ValueTask.CompletedTask;
    }
}
