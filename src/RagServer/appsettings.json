{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Rag": {
    "QueueMaxDepth": 50,
    "EmbeddingCacheSize": 1000,
    "MaxOutputTokens": 512,
    "DocsTopK": 5,
    "RrfRankConstant": 60,
    "DataMaxRetries": 1,
    "DataIrMaxTokens": 500
  },
  "Confluence": {
    "BaseUrl": "https://your-org.atlassian.net/wiki",
    "Username": "",
    "ApiToken": "",
    "Spaces": [],
    "IncrementalCron": "0 */6 * * *",
    "FullSyncCron": "0 2 * * 0",
    "RateLimitRps": 3
  },
  "Jira": {
    "BaseUrl": "https://your-org.atlassian.net",
    "Username": "",
    "ApiToken": "",
    "Projects": [],
    "IncrementalCron": "0 */6 * * *",
    "RateLimitRps": 3
  },
  "Ingestion": {
    "ChunkTargetTokens": 500,
    "ChunkOverlapTokens": 50,
    "BatchEmbedSize": 32
  }
}
